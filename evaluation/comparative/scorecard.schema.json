{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://world-class-seo.local/schemas/comparative-scorecard.json",
  "title": "Comparative SEO System Scorecard",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "as_of", "target_repository", "comparator", "formula", "categories", "overall_score"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "as_of": {"type": "string", "format": "date"},
    "target_repository": {"type": "string", "minLength": 3},
    "comparator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "commit", "license"],
      "properties": {
        "repository": {"type": "string"},
        "commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "license": {"type": "string"}
      }
    },
    "formula": {
      "const": "sum((score / 10) * weight)"
    },
    "categories": {
      "type": "array",
      "minItems": 10,
      "maxItems": 10,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "weight", "score", "evidence_maturity", "evidence", "open_gaps"],
        "properties": {
          "id": {"type": "integer", "minimum": 1, "maximum": 10},
          "name": {"type": "string"},
          "weight": {"type": "number", "exclusiveMinimum": 0},
          "score": {"type": "number", "minimum": 0, "maximum": 10},
          "evidence_maturity": {
            "type": "string",
            "enum": ["ABSENT", "DOCUMENTED", "STUB", "FUNCTIONAL", "LIVE_CAPABLE", "PRODUCTION_READY", "BEST_IN_CLASS"]
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["source", "claim", "state"],
              "properties": {
                "source": {"type": "string"},
                "claim": {"type": "string"},
                "state": {"enum": ["VERIFIED", "PARTIAL", "STALE", "UNVERIFIED"]}
              }
            }
          },
          "open_gaps": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "overall_score": {"type": "number", "minimum": 0, "maximum": 100},
    "target_score": {"type": "number", "minimum": 0, "maximum": 100, "default": 92},
    "notes": {"type": "array", "items": {"type": "string"}}
  }
}
