{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SEO Agent Handoff Payload",
  "description": "Minimum contract for passing work from one SEO agent to another and recording consumption.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "handoff_id",
    "from_agent",
    "to_agent",
    "reason",
    "context_summary",
    "evidence_refs",
    "requested_action",
    "risk_level",
    "acceptance_criteria",
    "due_trigger"
  ],
  "properties": {
    "handoff_id": {"type": "string"},
    "from_agent": {"type": "string"},
    "to_agent": {"type": "string"},
    "reason": {"type": "string"},
    "context_summary": {"type": "string"},
    "evidence_refs": {"type": "array", "items": {"type": "string"}},
    "requested_action": {"type": "string"},
    "risk_level": {
      "type": "string",
      "enum": ["Critical", "High", "Medium", "Low"]
    },
    "acceptance_criteria": {"type": "array", "items": {"type": "string"}},
    "due_trigger": {"type": "string"},
    "status": {
      "type": "string",
      "enum": ["CREATED", "CONSUMED", "BLOCKED"]
    },
    "receiving_output_id": {"type": "string"},
    "consumed_at": {"type": "string"}
  },
  "examples": [
    {
      "handoff_id": "handoff-technical-to-engineer-001",
      "from_agent": "SEO Technical Agent",
      "to_agent": "Senior SEO Engineer Agent",
      "reason": "Template-level canonical bug requires code implementation.",
      "context_summary": "Localized product pages emit canonical URLs pointing to the US version.",
      "evidence_refs": ["tech-001", "crawl-export-2026-07-03.csv"],
      "requested_action": "Patch product template canonical generation and add regression test.",
      "risk_level": "High",
      "acceptance_criteria": ["Localized sample URLs self-canonicalize", "Existing US product URLs unchanged"],
      "due_trigger": "Before international sitemap resubmission",
      "status": "CREATED",
      "receiving_output_id": "",
      "consumed_at": ""
    }
  ]
}
