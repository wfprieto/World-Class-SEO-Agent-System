{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://world-class-seo.local/schemas/reviewer-verdict.json",
  "title": "Independent Improvement Reviewer Verdict",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "review_id",
    "reviewer_id",
    "role",
    "context_id",
    "provider",
    "model",
    "evidence_package_hash",
    "verdict",
    "strongest_objections",
    "evidence_refs",
    "submitted_at"
  ],
  "properties": {
    "review_id": {"type": "string", "minLength": 3},
    "reviewer_id": {"type": "string", "minLength": 3},
    "role": {"enum": ["SENIOR_SCRUMMASTER_3", "VP_ENGINEERING"]},
    "context_id": {"type": "string", "minLength": 8},
    "provider": {"type": "string", "minLength": 2},
    "model": {"type": "string", "minLength": 2},
    "evidence_package_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "verdict": {"enum": ["REJECT_BAD", "REWORK_GOOD", "APPROVE_GREAT"]},
    "strongest_objections": {
      "type": "array",
      "minItems": 3,
      "items": {"type": "string", "minLength": 8}
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 2}
    },
    "residual_risks": {
      "type": "array",
      "items": {"type": "string"}
    },
    "required_changes": {
      "type": "array",
      "items": {"type": "string"}
    },
    "submitted_at": {"type": "string", "format": "date-time"},
    "saw_other_reviewer_verdict": {"const": false},
    "is_builder": {"const": false}
  }
}
