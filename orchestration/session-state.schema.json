{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SEO Session State",
  "description": "Shared state object for coordinated multi-agent SEO workflows.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "session_id",
    "request",
    "mode",
    "business_context",
    "business_profile_resolution",
    "evidence_inventory",
    "agent_outputs",
    "handoffs",
    "decisions",
    "open_risks"
  ],
  "properties": {
    "session_id": {"type": "string"},
    "request": {"type": "string"},
    "mode": {
      "type": "string",
      "enum": ["Audit", "Implementation", "Strategy", "Monitoring", "Research", "Debate"]
    },
    "business_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["domain", "business_type", "markets", "goals"],
      "properties": {
        "domain": {"type": "string"},
        "business_type": {"type": "string"},
        "markets": {"type": "array", "items": {"type": "string"}},
        "goals": {"type": "array", "items": {"type": "string"}}
      }
    },
    "business_profile_resolution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profiles",
        "route",
        "confidence",
        "scores",
        "observed_signals",
        "user_override",
        "missing_evidence",
        "action",
        "authority"
      ],
      "properties": {
        "profiles": {
          "type": "array",
          "items": {
            "enum": ["generic", "ecommerce", "local-service", "saas", "publisher", "agency-b2b"]
          },
          "minItems": 1
        },
        "route": {"enum": ["SINGLE", "HYBRID", "UNCONFIRMED"]},
        "confidence": {"enum": ["High", "Medium", "Low"]},
        "scores": {
          "type": "object",
          "additionalProperties": {"type": "integer"}
        },
        "observed_signals": {"type": "array", "items": {"type": "string"}},
        "user_override": {"type": "array", "items": {"type": "string"}},
        "missing_evidence": {"type": "array", "items": {"type": "string"}},
        "action": {"type": "string"},
        "authority": {"type": "string"}
      }
    },
    "evidence_inventory": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "source", "type", "status"],
        "properties": {
          "id": {"type": "string"},
          "source": {"type": "string"},
          "type": {"type": "string"},
          "status": {"enum": ["available", "missing", "partial", "stale", "invalid", "blocked"]},
          "notes": {"type": "string"}
        }
      }
    },
    "agent_outputs": {
      "type": "array",
      "description": "Every item must satisfy the canonical agent-output contract.",
      "items": {"$ref": "../schemas/agent-output.schema.json"}
    },
    "handoffs": {
      "type": "array",
      "description": "Every handoff records creation and consumption state.",
      "items": {"$ref": "../schemas/handoff-payload.schema.json"}
    },
    "decisions": {
      "type": "array",
      "description": "Scrummaster or strategist decision records.",
      "items": {"$ref": "../schemas/decision-record.schema.json"}
    },
    "open_risks": {"type": "array", "items": {"type": "string"}},
    "workflow_status": {
      "type": "string",
      "enum": ["PLANNED", "RUNNING", "PARTIAL", "BLOCKED", "FAILED", "COMPLETE"]
    },
    "workflow_events": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["event_id", "node_id", "agent", "state", "timestamp", "detail"],
        "properties": {
          "event_id": {"type": "string"},
          "node_id": {"type": "string"},
          "agent": {"type": "string"},
          "state": {"type": "string"},
          "timestamp": {"type": "string"},
          "detail": {"type": "string"}
        }
      }
    },
    "execution_limits": {"type": "object"},
    "budget_usage": {"type": "object"}
  },
  "examples": [
    {
      "session_id": "seo-session-20260703-001",
      "request": "Run a technical SEO and GEO readiness audit for example.com.",
      "mode": "Audit",
      "business_context": {
        "domain": "https://www.example.com",
        "business_type": "SaaS",
        "markets": ["United States", "Canada"],
        "goals": ["Increase qualified organic demos", "Improve AI citation readiness"]
      },
      "business_profile_resolution": {
        "profiles": ["saas"],
        "route": "SINGLE",
        "confidence": "High",
        "scores": {"saas": 0},
        "observed_signals": [],
        "user_override": ["saas"],
        "missing_evidence": [],
        "action": "run_declared_profile",
        "authority": "docs/plugin-packaging.md section 9"
      },
      "evidence_inventory": [
        {
          "id": "evidence-crawl-001",
          "source": "crawl-export-2026-07-03.csv",
          "type": "crawl_export",
          "status": "available",
          "notes": "Sample crawl of priority templates."
        }
      ],
      "agent_outputs": [],
      "handoffs": [],
      "decisions": [],
      "open_risks": [],
      "workflow_status": "PLANNED",
      "workflow_events": [],
      "execution_limits": {},
      "budget_usage": {}
    }
  ]
}
