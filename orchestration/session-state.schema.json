{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SEO Session State",
  "description": "Shared state object for multi-agent SEO workflows.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "session_id",
    "request",
    "mode",
    "business_context",
    "evidence_inventory",
    "agent_outputs",
    "handoffs",
    "decisions",
    "open_risks"
  ],
  "properties": {
    "session_id": {
      "type": "string",
      "description": "Unique workflow/session identifier."
    },
    "request": {
      "type": "string",
      "description": "Original user or project request."
    },
    "mode": {
      "type": "string",
      "enum": ["Audit", "Implementation", "Strategy", "Monitoring", "Research", "Debate"],
      "description": "Operating mode for the current run."
    },
    "business_context": {
      "type": "object",
      "description": "Business and market context required to interpret SEO evidence and prioritize work.",
      "additionalProperties": false,
      "required": ["domain", "business_type", "markets", "goals"],
      "properties": {
        "domain": {
          "type": "string",
          "description": "Primary site or property under review."
        },
        "business_type": {
          "type": "string",
          "description": "Business model or site type, such as SaaS, local service, ecommerce, publisher, marketplace, or enterprise."
        },
        "markets": {
          "type": "array",
          "description": "Target countries, regions, languages, or market segments.",
          "items": { "type": "string" }
        },
        "goals": {
          "type": "array",
          "description": "Business and SEO outcomes the workflow should optimize for.",
          "items": { "type": "string" }
        }
      }
    },
    "evidence_inventory": {
      "type": "array",
      "description": "All evidence artifacts collected during the workflow.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "source", "type", "status"],
        "properties": {
          "id": { "type": "string" },
          "source": { "type": "string" },
          "type": { "type": "string" },
          "status": { "enum": ["available", "missing", "partial", "stale"] },
          "notes": { "type": "string" }
        }
      }
    },
    "agent_outputs": {
      "type": "array",
      "description": "Agent outputs conforming to agent-output.schema.json.",
      "items": { "type": "object" }
    },
    "handoffs": {
      "type": "array",
      "description": "Agent handoffs conforming to handoff-payload.schema.json.",
      "items": { "type": "object" }
    },
    "decisions": {
      "type": "array",
      "description": "Scrummaster or strategist decision records.",
      "items": { "type": "object" }
    },
    "open_risks": {
      "type": "array",
      "description": "Open risks that must be resolved or accepted.",
      "items": { "type": "string" }
    }
  },
  "examples": [
    {
      "session_id": "seo-session-20260703-001",
      "request": "Run a technical SEO and GEO readiness audit for example.com.",
      "mode": "Audit",
      "business_context": {
        "domain": "https://www.example.com",
        "business_type": "SaaS",
        "markets": ["United States", "Canada"],
        "goals": ["Increase qualified organic demos", "Improve AI citation readiness"]
      },
      "evidence_inventory": [
        {
          "id": "evidence-crawl-001",
          "source": "crawl-export-2026-07-03.csv",
          "type": "crawl_export",
          "status": "available",
          "notes": "Sample crawl of priority templates."
        },
        {
          "id": "evidence-gsc-001",
          "source": "Google Search Console",
          "type": "first_party_data",
          "status": "missing",
          "notes": "Access not available for this run."
        }
      ],
      "agent_outputs": [],
      "handoffs": [],
      "decisions": [],
      "open_risks": ["GSC unavailable; performance findings will be lower confidence."]
    }
  ]
}
