# Optional runtime provider settings.
# Copy to .env locally if needed. Never commit real secrets.

# LLM_PROVIDER can be echo, openai, openai-compatible, or anthropic.
LLM_PROVIDER=echo

# OpenAI-compatible execution
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic execution
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
